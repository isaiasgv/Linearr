#!/bin/sh
# Block commits where the git author name or email contains "claude"

AUTHOR=$(git config user.name 2>/dev/null)
EMAIL=$(git config user.email 2>/dev/null)

if echo "$AUTHOR $EMAIL" | grep -qi "claude"; then
  echo ""
  echo "  [pre-commit] Rejected: git author name/email contains 'claude'."
  echo "  Update with: git config user.name 'Your Name'"
  echo "               git config user.email 'you@example.com'"
  echo ""
  exit 1
fi
