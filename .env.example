# ─── Required ──────────────────────────────────────────
APP_USERNAME=admin
APP_PASSWORD=changeme
APP_SECRET=generate-a-random-string-here

# Plex server URL (use container hostname if on the same Docker network)
PLEX_URL=http://plex:32400
PLEX_TOKEN=your-plex-token

# ─── Optional: AI features ────────────────────────────
# At least one key required for AI advisor / content suggestions
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional: Tunarr ─────────────────────────────────
# Configure Tunarr URL in the Settings UI, or set here
# TUNARR_URL=http://tunarr:8000
